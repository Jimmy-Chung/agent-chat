{
  "name": "agent-chat",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm -F mock-pi dev\" \"pnpm -F server dev\" \"pnpm -F web dev\"",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "biome format --write .",
    "format:check": "biome format --check .",
    "lint": "biome lint --write .",
    "lint:check": "biome lint .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  }
}
