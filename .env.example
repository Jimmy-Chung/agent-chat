# agent-chat 环境变量模板
# 复制为 .env 并填入实际值

# 鉴权 Token (64 hex)
AGENT_CHAT_TOKEN=replace-me-64-hex

# PI Adapter (mock-pi 用 ws://127.0.0.1:7331, 生产用实际地址)
PI_ADAPTER_URL=ws://127.0.0.1:7331/api/agent-chat/v1/socket
PI_ADAPTER_TOKEN=replace-me-64-hex

# 数据库
DB_PATH=./data/agent-chat.db

# 服务端口
PORT=8080

# R2 对象存储 (Part 2 启用)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=agent-chat-artifacts
R2_PUBLIC_URL=https://your-r2-bucket.example
