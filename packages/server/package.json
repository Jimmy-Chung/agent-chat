{
  "name": "@agent-chat/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:link-stress": "tsx scripts/link-stress.ts",
    "test:link-verify": "tsx scripts/link-stress/link-verify.ts",
    "test:link-fault": "tsx scripts/link-stress/link-verify.ts fault",
    "test:link-comm": "tsx scripts/link-stress/link-verify.ts all-with-fault",
    "build": "tsc",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@agent-chat/protocol": "workspace:*",
    "drizzle-orm": "^0.39.3",
    "hono": "^4.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.0",
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.4",
    "@types/ws": "^8.18.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.30.5",
    "socks-proxy-agent": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1",
    "wrangler": "^3.101.0",
    "ws": "^8.18.0"
  }
}
